# =====================
# Python .gitignore
# =====================

# --- Byte-compiled / Optimized / DLL files ---
__pycache__/
*.py[cod]
*$py.class

# --- Distribution / Packaging ---
build/
dist/
*.egg-info/
*.egg
wheels/
sdist/

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/

# --- uv specific ---
# uv.lock              # Uncomment if you do NOT want to track the lockfile
.python-version         # Optional: uncomment if you don't want to track pinned version

# --- Environment Variables ---
.env
.env.*
!.env.example

# --- IDE / Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# --- Mypy ---
.mypy_cache/

# --- Ruff ---
.ruff_cache/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Docker ---
docker-compose.override.yml

# --- Database ---
*.db
*.sqlite3

# --- Secrets / Credentials ---
*.pem
*.key
*.crt
secrets/

# --- Airflow ---
airflow/logs/*