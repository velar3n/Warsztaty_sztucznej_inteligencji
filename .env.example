# Port Mappings
SPARK_MASTER_UI_PORT=8080
SPARK_MASTER_PORT=7077
AIRFLOW_WEB_PORT=8081

# Spark Master Configuration
SPARK_MASTER_HOST=spark-master
SPARK_DRIVER_MEMORY=2G
SPARK_RPC_MESSAGE_MAXSIZE=512
SPARK_DRIVER_MAXRESULTSIZE=2g

# Spark Worker Configuration
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# Airflow Configuration
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_LOAD_EXAMPLES=False

# Airflow Database
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=airflow_metadata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Airflow Admin User
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Project Paths
AIRFLOW_DAGS_PATH=./airflow/dags
SPARK_JOBS_PATH=./spark/jobs
DATA_CLEANED_PATH=./data/cleaned
DATA_TRAINING_PATH=./data/training

# ChEMBL Database Configuration
CHEMBL_DB_HOST=host.docker.internal
CHEMBL_DB_PORT=5432
CHEMBL_DB_NAME=chembl
CHEMBL_DB_USER=postgres
CHEMBL_DB_PASSWORD=password

# ChEMBL Features Database Configuration
CHEMBL_FEATURES_DB_HOST=host.docker.internal
CHEMBL_FEATURES_DB_PORT=5432
CHEMBL_FEATURES_DB_NAME=chembl_features
CHEMBL_FEATURES_DB_USER=postgres
CHEMBL_FEATURES_DB_PASSWORD=password

# Spark Job Configuration
SPARK_EXECUTOR_MEMORY=2g
SPARK_TOTAL_EXECUTOR_CORES=4
SPARK_NUMPARTITIONS_ACTIVITIES=16
SPARK_NUMPARTITIONS_ASSAYS=8
SPARK_NUMPARTITIONS_COMPOUNDS=8
SPARK_REPARTITION_SIZE=16

# Airflow DAG Configuration
DAG_START_DATE=2025-12-10
DAG_SCHEDULE_INTERVAL=None